JWT_SECRET_KEY=otro_secreto_jwt

# MySQL Hostinger
# Formato: mysql+pymysql://usuario:password@localhost:3306/nombre_db
# En Hostinger el host MySQL es SIEMPRE localhost cuando te conectas desde el mismo VPS
DATABASE_URL=mysql+pymysql://u123456789_dca:TU_PASSWORD@localhost:3306/u123456789_dca

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
